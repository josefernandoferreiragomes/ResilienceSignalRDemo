@page "/management"
@using ManagementDashboard.Models
@using Microsoft.AspNetCore.SignalR.Client
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Example Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

<h3>Configure Producer Error Chance</h3>

<div>
    <label>Error Chance:</label>
    <InputNumber @bind-Value="errorChanceModel.ErrorChance" />
</div>
<div>
    <button type="button" @onclick="SendErrorChanceUpdate">Update Error Chance</button>
</div>

<p>Current Local Input: @errorChanceModel.ErrorChance</p>

@code {
    private HubConnection? hubConnection;

    private ErrorChanceModel errorChanceModel = new();
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }

    protected override async Task OnInitializedAsync()
    {
        await StartHubConnectionAsync();
    }

    private async Task StartHubConnectionAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:5003/confighub")
            .WithAutomaticReconnect()
            .Build();

        // Subscribe to broadcasts before connecting
        hubConnection.On<double>("BroadcastErrorChance", (newChance) =>
            {
                errorChanceModel.ErrorChance = newChance;
                InvokeAsync(StateHasChanged);
            });

        if (hubConnection is not null &&
            hubConnection.State == HubConnectionState.Disconnected)
        {
            try
            {
                await hubConnection.StartAsync();
                Console.WriteLine("Hub connection started.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error starting hub connection: {ex.Message}");
            }
        }
}

    private async Task SendErrorChanceUpdate()
    {
        try
        {
            Console.WriteLine("Button clicked!");
            if (hubConnection is not null &&
                hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.InvokeAsync("UpdateErrorChance", errorChanceModel.ErrorChance);
                await InvokeAsync(StateHasChanged);  // Use InvokeAsync for StateHasChanged
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating error chance: {ex.Message}");
        }
    }
}
