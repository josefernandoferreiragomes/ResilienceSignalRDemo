@page "/management"
@using ManagementDashboard.Models
@using System.Globalization
@using Microsoft.AspNetCore.SignalR.Client
@inject IHttpClientFactory ClientFactory
@inject IConfiguration config
@implements IAsyncDisposable
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Polly and SignalR Demo</PageTitle>

<section>
    <h5>SignalR ConfigHub</h5>
    <div class="row">
        <div class="col-6">
            <label>Config Hub health:</label>
            <span class="text-primary">@hubHealth</span>
        </div>
        <div class="col-6">
            <button class="btn btn-primary m-1" @onclick="CheckHubHealth">Check Hub Health</button>
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <label>Config Hub Error Chance:</label>
            <span class="text-primary">@errorChance</span>
        </div>
        <div class="col-6">
            <button class="btn btn-primary m-1" @onclick="CheckHubErrorChance">Get Error Chance</button>
        </div>
    </div>
</section>
<section>
    <h6>Configure Producer Error Chance</h6>
    <div class="row">
        <div class="col-6">
            <label>Error Chance:</label>
            <InputNumber @bind-Value="errorChanceModel.ErrorChance" />
        </div>
        <div class="col-6">
            <button class="btn btn-primary m-1" @onclick="SendErrorChanceUpdate">Update Error Chance</button>
        </div>
    </div>
</section>
<section>
    <h6>Producer's hub connection</h6>
    <div class="row">
        <div class="col-6">
            <label>Status:</label>
            <span class="text-primary">@producerHubConnection</span>
        </div>
        <div class="col-6">
            <button class="btn btn-primary m-1" @onclick="StartProducer">Start Producer and verify status</button>
        </div>
    </div>
</section>
    <div class="row">
        <div class="col-12 mb-2">
            <button class="btn btn-primary" style="background:#0d6efd;color:#fff;padding:.375rem .75rem;border-radius:.25rem" @onclick="RefreshTimeline">Refresh Timeline</button>
        </div>
    </div>
<hr />
<section>
    <h5>Polly Dashboard</h5>
    <h6>Metrics</h6>
    <div class="row">
        <div class="col-6">
            <label>Total Calls:</label>
            <span class="text-primary">@metricsModel?.TotalCalls</span>
        </div>
        <div class="col-6">
            <label>Retries Fired:</label>
            <span class="text-primary">@metricsModel?.RetryCount</span>
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <label>Circuit State:</label>
            <span class="text-primary">@metricsModel?.CircuitState</span>
        </div>
        <div class="col-6">
            <label>Last Reset:</label>
            <span class="text-primary">@metricsModel?.LastReset</span>
        </div>
    </div>
    <div class="row mt-2">
        <div class="col-12">
            <button class="btn btn-outline-primary" @onclick="RefreshMetrics">Refresh Metrics</button>
        </div>
    </div>
    <hr />
    <h6>Configuration</h6>
    <div class="row">
        <div class="col-3">
            <label>Retry Count:</label>
        </div>
        <div class="col-3">
            <InputNumber @bind-Value="resilienceConfigModel.RetryCount" />
        </div>
        <div class="col-3">
            <label>Exponential Backoff (ms):</label>
        </div>
        <div class="col-3">
            <InputText @bind-Value="backoffInput" />
        </div>
    </div>
    <div class="row">
        <div class="col-3">
            <label>Exceptions Before Breaking:</label>
        </div>
        <div class="col-3">
            <InputNumber @bind-Value="resilienceConfigModel.ExceptionsAllowedBeforeBreaking" />
        </div>
        <div class="col-3">
            <label>Break Duration (s):</label>
        </div>
        <div class="col-3">
            <InputNumber @bind-Value="resilienceConfigModel.DurationOfBreakInSeconds" />
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <button class="btn btn-primary m-1" @onclick="UpdatePollyConfiguration">Update Configuration</button>
        </div>
    </div>
</section>
<hr />
<section>
    <h6>Test Consumer API</h6>
    <div class="row">
        <div class="col-3">
            <label>Successive Calls</label>
        </div>
        <div class="col-3">
            <InputNumber @bind-Value="successiveCalls" />
        </div>
        <div class="col-6">
            <InputRadioGroup @bind-Value="isParallel">
                <div class="form-check form-check-inline">
                    <InputRadio class="form-check-input" Value="true" /> 
                    <label class="form-check-label">Parallel</label>
                </div>
                <div class="form-check form-check-inline ms-4">
                    <InputRadio class="form-check-input" Value="false" /> 
                    <label class="form-check-label">Sequential</label>
                </div>
            </InputRadioGroup>
        </div>
    </div>
    <div class="row">
        <div class="col-6">
            <button class="btn btn-primary m-1" @onclick="TestConsumerApi">Send Test Consume Request</button>
        </div>
        <div class="col-6">
            <label>Status</label>
            <span class="text-primary">@requestStatus</span>
        </div>
    </div>
</section>

<!-- Timeline Charts Section (placed at the bottom of the management page) -->
<hr />
<section>
    <h5>Timeline Charts</h5>
    <p class="text-muted">Manual refresh with the "Refresh Timeline" button above. Shows last 30 minutes by default.</p>
    <div class="row">
        <div class="col-12">
            <h6>Circuit Breaker State</h6>
            <div style="position:relative; width:100%; height:180px;">
                <canvas id="circuitChart" aria-label="Circuit breaker timeline"></canvas>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <h6>Producer Responses (status codes)</h6>
            <div style="position:relative; width:100%; height:180px;">
                <canvas id="producerChart" aria-label="Producer responses timeline"></canvas>
            </div>
        </div>
        <div class="col-12">
            <h6>Consumer Attempts & Retries</h6>
            <div style="position:relative; width:100%; height:180px;">
                <canvas id="consumerChart" aria-label="Consumer attempts timeline"></canvas>
            </div>
        </div>
    </div>
</section>

@code {
    const double svgWidth = 900.0;
    const double svgHeight = 120.0;
    private HubConnection? hubConnection;

    private HttpClient ConsumerApiClient => ClientFactory.CreateClient("ConsumerApi");
    private HttpClient ConfigApiClient => ClientFactory.CreateClient("ConfigApi");
    private HttpClient ProducerApiClient => ClientFactory.CreateClient("ProducerApi");

    private ErrorChanceModel errorChanceModel = new();
    private MetricsModel? metricsModel = new();
    private ResilienceConfigModel resilienceConfigModel = new();

    private bool isParallel = true;

    private int successiveCalls = 1;

    private string backoffInput = "";

    private string hubHealth = "";

    private string errorChance = "";

    private string requestStatus = "Ready to send requests";

    private string producerHubConnection = "Not started";

    // Timeline data
    private DateTime timelineFrom = DateTime.UtcNow.AddMinutes(-30);
    private DateTime timelineTo = DateTime.UtcNow;
    private List<TimelineEventModel>? consumerEvents;
    private List<TimelineEventModel>? producerEvents;
    private List<(DateTime TimestampUtc, double Value)>? circuitPoints;

    private async Task RefreshTimeline()
    {
        try
        {
            var events = await ConsumerApiClient.GetFromJsonAsync<List<TimelineEventModel>>($"timeline?minutes=30");
            if (events is null)
            {
                consumerEvents = new();
                producerEvents = new();
                circuitPoints = new();
                return;
            }
            // Debug: log raw timeline event count and a short sample for troubleshooting
            try
            {
                Console.WriteLine($"[Management] Raw timeline events: {events.Count}");
                foreach (var ev in events.Take(10))
                {
                    Console.WriteLine($"[Management] Event: Kind={ev.Kind}, Timestamp={ev.TimestampUtc:O}, StatusCode={(ev.StatusCode.HasValue ? ev.StatusCode.Value.ToString() : "null")}, Detail={ev.Detail}");
                }
            }
            catch { }
            timelineTo = DateTime.UtcNow;
            timelineFrom = timelineTo.AddMinutes(-30);

            consumerEvents = events.Where(e => e.Kind == "ConsumerRequest" && e.TimestampUtc >= timelineFrom).OrderBy(e => e.TimestampUtc).ToList();
            // Include any event that carries a status code (non-null) so error responses (4xx/5xx) are included
            producerEvents = events.Where(e => e.StatusCode.HasValue && e.TimestampUtc >= timelineFrom).OrderBy(e => e.TimestampUtc).ToList();
            var circuit = events.Where(e => e.Kind == "CircuitState" && e.TimestampUtc >= timelineFrom).OrderBy(e => e.TimestampUtc).ToList();
            // Build stepped points for circuit state so the chart shows a step function across the window
                        var points = new List<(DateTime TimestampUtc, double Value)>();
                        double currentState = 0.0; // assume Closed
                        if (circuit.Any())
                        {
                            // start with state at window start (use first event's previous state if available)
                            // we do not know previous state, so use the first event's state as starting value
                            var first = circuit.First();
                            currentState = first.State == "Open" ? 1.0 : first.State == "HalfOpen" ? 0.5 : 0.0;
                            points.Add((timelineFrom, currentState));
                            foreach (var e in circuit)
                            {
                                var newState = e.State == "Open" ? 1.0 : e.State == "HalfOpen" ? 0.5 : 0.0;
                                // add a point at event time with previous state to end the previous step
                                points.Add((e.TimestampUtc, currentState));
                                // add a point at same time with new state to start the new step
                                points.Add((e.TimestampUtc, newState));
                                currentState = newState;
                            }
                            // close the last step to timeline end
                            points.Add((timelineTo, currentState));
                        }
                        else
                        {
                            // no events: show flat line using last known metrics state if available
                            var s = metricsModel?.CircuitState ?? "Closed";
                            currentState = s == "Open" ? 1.0 : s == "HalfOpen" ? 0.5 : 0.0;
                            points.Add((timelineFrom, currentState));
                            points.Add((timelineTo, currentState));
                        }
                        circuitPoints = points;

            StateHasChanged();

            // Build a unified labels array from the circuit points timestamps so all charts align horizontally
            // Use millisecond precision for labels to avoid collapsing events that occur within the same second
            var labels = circuitPoints.Select(p => p.TimestampUtc.ToString("HH:mm:ss.fff")).ToArray();
            var data = circuitPoints.Select(p => p.Value).ToArray();
            await Task.Yield();
            await JS.InvokeVoidAsync("timelineCharts.renderCircuit", "circuitChart", labels, data);

            // Map producer events into an array aligned to the unified labels
            // var labelIndex = labels.Select((l, i) => new { l, i }).ToDictionary(x => x.l, x => x.i);
            // var producerAligned = Enumerable.Repeat(0.0, labels.Length).ToArray();
            // foreach (var pe in producerEvents)
            // {
            //     var key = pe.TimestampUtc.ToString("HH:mm:ss");
            //     if (labelIndex.TryGetValue(key, out var idx))
            //     {
            //         producerAligned[idx] = pe.StatusCode.HasValue ? (double)pe.StatusCode.Value : 0.0;
            //     }
            // }
            // await JS.InvokeVoidAsync("timelineCharts.renderStatus", "producerChart", labels, producerAligned, "Producer Status");
            // Include producer events that either carry a status code or contain detail (exceptions may come as Detail only)
            if (producerEvents is not null && producerEvents.Any())
            {
                var pLabels = producerEvents.Select(e => e.TimestampUtc.ToString("HH:mm:ss.fff")).ToArray();
                // Map null status codes (often exceptions) to 500 so they are visible as error points
                var pData = producerEvents.Select(e => (double)(e.StatusCode ?? 500)).ToArray();
                await JS.InvokeVoidAsync("timelineCharts.renderStatus", "producerChart", pLabels, pData, "Producer Status");
            }

            // Map consumer initial attempts and retries to the unified labels
            // var initialAligned = Enumerable.Repeat(0.0, labels.Length).ToArray();
            // var retryAligned = Enumerable.Repeat(0.0, labels.Length).ToArray();
            // foreach (var ce in consumerEvents)
            // {
            //     var key = ce.TimestampUtc.ToString("HH:mm:ss");
            //     if (labelIndex.TryGetValue(key, out var idx))
            //     {
            //         // mark initial attempt
            //         initialAligned[idx] = 1.0;
            //         // simplistic retry detection: if Detail contains 'retry' mark as retry (fallback)
            //         if (!string.IsNullOrEmpty(ce.Detail) && ce.Detail!.ToLowerInvariant().Contains("retry"))
            //         {
            //             retryAligned[idx] = 1.0;
            //         }
            //     }
            // }
            // await JS.InvokeVoidAsync("timelineCharts.renderAttempts", "consumerChart", labels, initialAligned, retryAligned);
            if (consumerEvents is not null && consumerEvents.Any())
            {
                var cLabels = consumerEvents.Select(e => e.TimestampUtc.ToString("HH:mm:ss.fff")).ToArray();
                var initialData = consumerEvents.Select(e => 1.0).ToArray();
                // Improve retry detection: check Kind for 'retry' (case-insensitive) in addition to Detail text
                var retryData = consumerEvents
                    .Select(e => ((!string.IsNullOrEmpty(e.Detail) && e.Detail!.IndexOf("retry", StringComparison.OrdinalIgnoreCase) >= 0)
                                   || (!string.IsNullOrEmpty(e.Kind) && e.Kind.IndexOf("retry", StringComparison.OrdinalIgnoreCase) >= 0)) ? 1.0 : 0.0)
                    .ToArray();
                await JS.InvokeVoidAsync("timelineCharts.renderAttempts", "consumerChart", cLabels, initialData, retryData);
            }

            // Debug: print event counts for quick verification in logs
            Console.WriteLine($"[Management] Timeline counts: consumer={consumerEvents?.Count ?? 0}, producer={producerEvents?.Count ?? 0}, circuitPoints={circuitPoints?.Count ?? 0}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing timeline: {ex.Message}");
        }
    }

    private async Task StartProducer()
    {
        try
        {
            //var response = await ProducerApiClient.GetAsync("startproducer");
            var response = await ProducerApiClient.PutAsJsonAsync("start", "testIinput");
            if (response.IsSuccessStatusCode)
            {
                producerHubConnection = "Started";
            }
            else
            {
                producerHubConnection = $"Failed to start: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            producerHubConnection = $"Error: {ex.Message}";
        }
    }
    protected override async Task OnInitializedAsync()
    {
        await StartHubConnectionAsync();
        await LoadPollyConfiguration();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // DOM is ready; refresh timeline now so canvases exist
            await RefreshTimeline();
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    private async Task StartHubConnectionAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(config["ConfigApi:HubUrl"]!)
            .WithAutomaticReconnect()
            .Build();

        // Subscribe to broadcasts before connecting
        hubConnection.On<double>("BroadcastErrorChance", (newChance) =>
            {
                errorChanceModel.ErrorChance = newChance;
                InvokeAsync(StateHasChanged);
            });

        if (hubConnection is not null &&
            hubConnection.State == HubConnectionState.Disconnected)
        {
            try
            {
                await hubConnection.StartAsync();
                Console.WriteLine("---------------------->[ManagementDashboard] [ConfigApi] Hub connection started.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"---------------------->[ManagementDashboard] [ConfigApi] Error *** starting hub connection: {ex.Message}");
            }
        }
    }

    private async Task CheckHubHealth()
    {
        hubHealth = await ConfigApiClient.GetStringAsync("health") ?? "Unknown";
    }
    private async Task CheckHubErrorChance()
    {
        errorChance = await ConfigApiClient.GetStringAsync("errorchance") ?? "Unknown";
    }
    private async Task SendErrorChanceUpdate()
    {
        try
        {
            Console.WriteLine("Button clicked!");
            if (hubConnection is not null &&
                hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.InvokeAsync("UpdateErrorChance", errorChanceModel.ErrorChance);
                await InvokeAsync(StateHasChanged);  // Use InvokeAsync for StateHasChanged
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating error chance: {ex.Message}");
        }
    }

    private async Task LoadPollyConfiguration()
    {
        resilienceConfigModel = await ConsumerApiClient.GetFromJsonAsync<ResilienceConfigModel>("config")
                 ?? new ResilienceConfigModel();
        backoffInput = string.Join(", ", resilienceConfigModel.RetryBackoffMilliseconds);
    }

    private async Task RefreshMetrics()
    {
        try
        {
            metricsModel = await ConsumerApiClient.GetFromJsonAsync<MetricsModel>("metrics");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing metrics: {ex.Message}");
        }
    }

    private async Task UpdatePollyConfiguration()
    {
        var list = backoffInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => int.Parse(s.Trim()))
            .ToList();
        resilienceConfigModel.RetryBackoffMilliseconds = list;
        await ConsumerApiClient.PutAsJsonAsync("config", resilienceConfigModel);
        // Optionally refresh immediately
        await RefreshMetrics();
    }

    private async Task TestConsumerApi()
    {
        requestStatus = "1: Sending requests...";
        if (isParallel)
        {
            Console.WriteLine("Running in parallel mode.");
            await Task.WhenAll(Enumerable.Range(0, successiveCalls).Select(async i =>
            {
                try
                {
                    var response = await ConsumerApiClient.GetAsync("consume");
                    if (response.IsSuccessStatusCode)
                    {
                        Console.WriteLine("Test Consume call succeeded.");
                    }
                    else
                    {
                        Console.WriteLine($"Test Consume call failed with status code: {response.StatusCode}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error during test Consume call: {ex.Message}");
                }
            }));

        }
        else
        {
            Console.WriteLine("Running in sequential mode.");
            for (int i = 0; i < successiveCalls; i++)
            {
                try
                {
                    var response = await ConsumerApiClient.GetAsync("consume");
                    if (response.IsSuccessStatusCode)
                    {
                        Console.WriteLine("Test Consume call succeeded.");
                    }
                    else
                    {
                        Console.WriteLine($"Test Consume call failed with status code: {response.StatusCode}");
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error during test Consume call: {ex.Message}");
                }

            }
        }
        requestStatus = "2: Completed requests.";
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
