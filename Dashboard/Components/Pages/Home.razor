@page "/"
@rendermode InteractiveAuto
@using Dashboard.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject IHttpClientFactory ClientFactory
@implements IAsyncDisposable

<h3>Configure Producer Error Chance</h3>

