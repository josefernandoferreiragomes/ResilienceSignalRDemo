<div>
    <label>Error Chance:</label>
    <InputNumber @bind-Value="errorChanceModel.ErrorChance" />
</div>
<div>
    <button type="button" @onclick="SendErrorChanceUpdate">Update Error Chance</button>
</div>

<p>Current Local Input: @errorChanceModel.ErrorChance</p>


<h3>Polly Dashboard</h3>

<section>
    <h4>Metrics</h4>
    <p>Total Calls: @metricsModel?.TotalCalls</p>
    <p>Retries Fired: @metricsModel?.RetryCount</p>
    <p>Circuit State: @metricsModel?.CircuitState</p>
    <p>Last Reset: @metricsModel?.LastReset</p>
    <button type="button" onclick='location.reload();'>Refresh1</button>
</section>

<hr />

<section>
    <h4>Configuration</h4>
    <EditForm Model="resilienceConfigModel" FormName="configurationForm" OnValidSubmit="UpdatePollyConfiguration">
        <ValidationSummary />
        <div>
            <label>Retry Count:</label>
            <InputNumber @bind-Value="resilienceConfigModel.RetryCount" />
        </div>
        <div>
            <label>Backoff (ms, comma-separated):</label>
            <InputText @bind-Value="backoffInput" />
        </div>
        <div>
            <label>Exceptions Before Breaking:</label>
            <InputNumber @bind-Value="resilienceConfigModel.ExceptionsAllowedBeforeBreaking" />
        </div>
        <div>
            <label>Break Duration (s):</label>
            <InputNumber @bind-Value="resilienceConfigModel.DurationOfBreakInSeconds" />
        </div>
        <button type="submit">Update</button>
    </EditForm>
</section>

@code {
    private HttpClient ConfigApiClient => ClientFactory.CreateClient("ConfigApi");
    private HttpClient ConsumerApiClient => ClientFactory.CreateClient("ConsumerApi");

    private HubConnection? hubConnection;
    private ErrorChanceModel errorChanceModel = new();

    private MetricsModel? metricsModel = new();
    private ResilienceConfigModel resilienceConfigModel = new();
    private string backoffInput = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadPollyConfiguration();
        await RefreshMetrics();

        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:5003/confighub")
            .WithAutomaticReconnect()
            .Build();

        // Subscribe to broadcasts before connecting
        hubConnection.On<double>("BroadcastErrorChance", (newChance) =>
        {
            errorChanceModel.ErrorChance = newChance;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await hubConnection.StartAsync();
            // Get initial value after connection
            await GetErrorChance();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error connecting to hub: {ex.Message}");
        }
    }

    // private async Task OnErrorChanceChanged(ChangeEventArgs e)
    // {
    //     if (double.TryParse(e.Value?.ToString(), out var newValue))
    //     {
    //         errorChance = newValue;
    //         await SendErrorChanceUpdate();
    //     }
    // }

    private async Task GetErrorChance()
    {
        try
        {
            if (hubConnection is not null &&
                hubConnection.State == HubConnectionState.Connected)
            {
                // Call the hub method to get current value
                var currentChance = await hubConnection.InvokeAsync<double>("GetErrorChance");
                errorChanceModel.ErrorChance = currentChance;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching error chance: {ex.Message}");
        }
    }
    
    private async Task SendErrorChanceUpdate()
    {
        try
        {
            Console.WriteLine("Button clicked!");
            if (hubConnection is not null &&
                hubConnection.State == HubConnectionState.Connected)
            {
                await hubConnection.InvokeAsync("UpdateErrorChance", errorChanceModel.ErrorChance);
                await InvokeAsync(StateHasChanged);  // Use InvokeAsync for StateHasChanged
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating error chance: {ex.Message}");                        
        }
    }   

    private async Task LoadPollyConfiguration()
    {
        resilienceConfigModel = await ConsumerApiClient.GetFromJsonAsync<ResilienceConfigModel>("config")
                 ?? new ResilienceConfigModel();
        backoffInput = string.Join(", ", resilienceConfigModel.RetryBackoffMilliseconds);
    }

    private async Task RefreshMetrics()
    {
        try
        {
            metricsModel = await ConsumerApiClient.GetFromJsonAsync<MetricsModel>("metrics");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing metrics: {ex.Message}");
        }
    }

    private async Task UpdatePollyConfiguration()
    {
        var list = backoffInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(s => int.Parse(s.Trim()))
            .ToList();
        resilienceConfigModel.RetryBackoffMilliseconds = list;
        await ConsumerApiClient.PutAsJsonAsync("config", resilienceConfigModel);
        // Optionally refresh immediately
        await RefreshMetrics();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}

